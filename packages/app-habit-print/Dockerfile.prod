# BASE
FROM node:24-alpine AS base

RUN apk add --no-cache curl

ENV NODE_ENV=production
ENV HOST=localhost
ENV PORT=10300

# BUILD
FROM base AS build

ENV NODE_ENV=development

WORKDIR /root

COPY package.json ./
COPY package-lock.json ./
RUN npm ci

COPY ./src ./src

EXPOSE ${PORT}

HEALTHCHECK \
  --interval=30s \
  --timeout=10s \
  --start-period=15s \
  --retries=3 \
  CMD curl --head --fail --silent http://${HOST}:${PORT}/health || exit 1

ENTRYPOINT ["npm", "run", "prod"]